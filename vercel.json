{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "gallery.html",
          "index.html",
          "shooting-gallery.jpg",
          "gallery-images/**",
          "cv-shatter/**",
          "hand-shatter/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
